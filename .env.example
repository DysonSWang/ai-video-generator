# AI视频生成系统 - 环境变量配置

# ========== 必需 ==========
JWT_SECRET=your-jwt-secret-here

# ========== AI服务 ==========
QWEN_API_KEY=your-qwen-api-key
SILICONFLOW_API_KEY=your-siliconflow-api-key
KLING_ACCESS_KEY=your-kling-access-key
KLING_SECRET_KEY=your-kling-secret-key

# ========== 文件存储 ==========
OSS_ACCESS_KEY=your-oss-access-key
OSS_SECRET_KEY=your-oss-secret-key
OSS_BUCKET=your-bucket-name
OSS_ENDPOINT=oss-cn-shenzhen.aliyuncs.com

# ========== GPU服务器 ==========
OMNIVOICE_PASSWORD=your-omnivoice-password
INFINITETALK_PASSWORD=your-infinitetalk-password

# ========== 可选 ==========
DATABASE_URL=postgresql://user:pass@host:5432/dbname  # 不设置则用 SQLite
WHISPER_MODEL=small
TOKEN_EXPIRE_MINUTES=1440
